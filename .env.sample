# Macrocosm — project config.
# Copy this file to `.env` (which is gitignored) and fill in the values below.
#
# How it loads (you do NOT source it manually):
#   - VS Code: the Python / Jupyter extension reads `.env` automatically (python.envFile).
#   - zsh + direnv: `.envrc` loads `.env` into your shell — run `direnv allow .` once.

# --- GCP ---
GCP_PROJECT=macrocosm-lewagon
GCP_REGION=europe-west1
BUCKET_NAME=macrocosm-lewagon

# --- GCS access: use YOUR OWN Google account (your Gmail already has IAM on the bucket) ---
# One-time, in a terminal:
#   gcloud auth application-default login                          # log in with THAT Gmail
#   gcloud auth application-default set-quota-project macrocosm-lewagon
# This var just sets the quota/billing project for your login:
GOOGLE_CLOUD_PROJECT=macrocosm-lewagon

# 🚨 Do NOT set GOOGLE_APPLICATION_CREDENTIALS to your personal-account flow — it OVERRIDES your
#    login and is the usual cause of `403 Forbidden` (it often points at the Le Wagon bootcamp SA).
#    If a course `.env`/`.zshrc` sets it, unset it for this project.
#
# (Fallback only) to use the shared service-account key instead of your own account, set the path
# below and skip the gcloud login above:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/sciserver-uploader.json

# --- Handy GCS paths (used by the notebooks/scripts) ---
CATALOG_GCS=gs://macrocosm-lewagon/data/sample_v1/catalog_v1.parquet
RESULTS_TAR_GCS=gs://macrocosm-lewagon/results/outlier_cv_results.tar.gz
