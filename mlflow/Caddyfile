{$HOST} {
	# Programmatic clients (e.g. Colab's MLflow client) send a static bearer token
	# -> route straight to mlflow, bypassing the browser-only oauth2-proxy.
	# Colab: set MLFLOW_TRACKING_TOKEN=<MLFLOW_API_TOKEN> (MLflow sends it as Bearer).
	@api header Authorization "Bearer {$MLFLOW_API_TOKEN}"
	handle @api {
		reverse_proxy mlflow:5000
	}

	# Browsers -> GitHub-org login via oauth2-proxy. While the VM has booted but
	# mlflow isn't serving yet (502/503/504), show an auto-refreshing "starting" page.
	handle {
		reverse_proxy oauth2-proxy:4180 {
			@starting status 502 503 504
			handle_response @starting {
				root * /srv
				rewrite * /starting.html
				file_server
			}
		}
	}
}
