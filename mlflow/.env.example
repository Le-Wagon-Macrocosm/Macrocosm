# Copy to .env ON THE VM and fill in. NEVER commit .env (it's gitignored).
GH_ORG=Le-Wagon-Macrocosm
GH_CLIENT_ID=            # from the new GitHub OAuth App (Settings -> Developer settings)
GH_CLIENT_SECRET=
COOKIE_SECRET=          # generate (URL-safe, decodes to 32 bytes): openssl rand -base64 32 | tr '+/' '-_'
HOST=                   # static IP with dashes + .sslip.io, e.g. 34-123-45-67.sslip.io
MLFLOW_API_TOKEN=       # shared bearer token for Colab/programmatic access: openssl rand -hex 32
